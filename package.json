{
  "name": "tile-guessr",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate": "pnpm --dir spacetimedb install && cargo run -p gen-bindings -- --out-dir src/module_bindings --project-path spacetimedb && prettier --write src/module_bindings",
    "spacetime:generate": "spacetime generate --lang typescript --out-dir src/module_bindings --project-path spacetimedb",
    "spacetime:publish:local": "spacetime publish --project-path spacetimedb --server local",
    "spacetime:publish": "spacetime publish --project-path spacetimedb --server maincloud"
  },
  "dependencies": {
    "spacetimedb": "^2.0.1"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/table-core": "^8.21.3",
    "@threlte/core": "^8.4.0",
    "@threlte/extras": "^9.8.1",
    "@types/node": "^25.3.3",
    "@types/three": "^0.183.1",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "^2.0.1",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.28.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^6.4.1"
  }
}
